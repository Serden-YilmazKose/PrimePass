# Normalize text files
* text=auto

# Shell scripts MUST be LF 
*.sh text eol=lf

# Docker / configs: keep LF
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf

# Python + Markdown: keep LF
*.py text eol=lf
*.md text eol=lf

# Windows-only scripts
*.bat text eol=crlf
*.ps1 text eol=crlf